<Window x:Class="WPFPaint.Dialogs.PluginManagerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление плагинами" Height="420" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Загруженные плагины:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <ListView x:Name="PluginListView" Grid.Row="1" Margin="0,0,0,12">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Загружать" Width="75">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled}" HorizontalAlignment="Center"
                                          Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Название" Width="180" DisplayMemberBinding="{Binding Name}"/>
                    <GridViewColumn Header="Автор" Width="140" DisplayMemberBinding="{Binding Author}"/>
                    <GridViewColumn Header="Версия" Width="80" DisplayMemberBinding="{Binding Version}"/>
                    <GridViewColumn Header="DLL" Width="100" DisplayMemberBinding="{Binding DllPath}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="100" Height="30" Margin="0,0,8,0" Click="Save_Click" IsDefault="True"/>
            <Button Content="Отмена" Width="100" Height="30" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
