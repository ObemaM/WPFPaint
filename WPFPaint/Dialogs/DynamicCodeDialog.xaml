<Window x:Class="WPFPaint.Dialogs.DynamicCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Динамический фильтр (C#)" Height="520" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        ShowInTaskbar="False" MinWidth="500" MinHeight="400">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="12">
            Введите код фильтра на C#. Доступны: <Bold>byte[] pixelData</Bold> (BGRA32), <Bold>int width</Bold>, <Bold>int height</Bold>.
            <LineBreak/>Каждый пиксель: pixelData[i*4]=B, pixelData[i*4+1]=G, pixelData[i*4+2]=R, pixelData[i*4+3]=A.
        </TextBlock>

        <TextBox x:Name="CodeTextBox" Grid.Row="1" AcceptsReturn="True" AcceptsTab="True" 
                 TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="13" Margin="0,0,0,8"
                 Text="// Пример: инверсия цвета (негатив)&#xA;for (int i = 0; i &lt; width * height; i++)&#xA;{&#xA;    int offset = i * 4;&#xA;    pixelData[offset] = (byte)(255 - pixelData[offset]); // B&#xA;    pixelData[offset + 1] = (byte)(255 - pixelData[offset + 1]); // G&#xA;    pixelData[offset + 2] = (byte)(255 - pixelData[offset + 2]); // R&#xA;}"/>

        <TextBlock x:Name="ErrorText" Grid.Row="2" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8" FontSize="11"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Применить" Width="100" Height="30" Margin="0,0,8,0" Click="Apply_Click" IsDefault="True"/>
            <Button Content="Закрыть" Width="100" Height="30" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
